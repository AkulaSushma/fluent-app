{
  "expo": {
    "name": "Engura",
    "slug": "engura",
    "scheme": "engura",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#F4F1EB",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "package": "com.lingura.engura",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#F4F1EB"
      },
      "permissions": [
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "plugins": [
      "expo-font",
      "expo-asset",
      "expo-status-bar",
      [
        "expo-audio",
        {
          "microphonePermission": "Allow Fluent to access your microphone for speech evaluation.",
          "recordAudioAndroid": true
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "02ff07af-fe3f-4281-9648-aadd4ff7a0e6"
      }
    }
  }
}
